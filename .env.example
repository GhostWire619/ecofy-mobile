# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── API ────────────────────────────────────────────────────────────────────
# Production:   https://api.ecofy.co.tz
# Local dev:    http://192.168.x.x:8021  (your machine's LAN IP for physical devices)
#               http://127.0.0.1:8021    (iOS simulator / web)
#               http://10.0.2.2:8021     (Android emulator)
# Leave empty to let the app auto-detect a local backend from the Expo host URI.
EXPO_PUBLIC_API_BASE_URL=https://api.ecofy.co.tz

# ─── Environment ─────────────────────────────────────────────────────────────
# Values: local | staging | production
EXPO_PUBLIC_ENVIRONMENT=local

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Get your token at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_token_here
EXPO_PUBLIC_MAPBOX_STYLE_URL=mapbox://styles/mapbox/satellite-streets-v12

# ─── EAS (Expo Application Services) ────────────────────────────────────────
# Found in your EAS dashboard or run `eas init` to generate one.
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id-here
