{
  "name": "ecofy-mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:lan": "expo start --dev-client --lan",
    "start:tunnel": "expo start --dev-client --tunnel",
    "start:clear": "expo start --dev-client -c",
    "logs:android": "adb logcat -v time ReactNativeJS:V ReactNative:V Expo:V *:S",
    "logs:android:ecofy": "powershell -NoProfile -Command \"adb logcat -v time | Select-String -Pattern 'ecofy-api|ReactNativeJS|ReactNative|Expo'\"",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "openapi:export": "powershell -ExecutionPolicy Bypass -File ./scripts/export-openapi.ps1"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@rnmapbox/maps": "^10.3.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.99.2",
    "date-fns": "^4.1.0",
    "expo": "~55.0.15",
    "expo-background-task": "~55.0.16",
    "expo-constants": "~55.0.14",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-task-manager": "~55.0.14",
    "expo-web-browser": "~55.0.14",
    "mapbox-gl": "^2.15.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "expo-modules-core": "~55.0.22",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
